---
// Define the TypeScript interface for the skill structure
interface Skill {
    type: string;
    name: string;
    subtext?: string;
    levelText?: string;
    levelPercentage: number; // e.g., 80 for 80%
    projects?: { name: string; url?: string }[];
}

interface Props {
    skills: Skill[];
}

let { skills } = Astro.props;
---

<div class="skills-table-wrapper">
    <table class="skills-table">
        <thead>
        <tr>
            <!--<th>Category</th>-->
            <th>Skill</th>
            <th>Level</th>
            <th class="hide-mobile">Featured Projects</th>
        </tr>
        </thead>
        <tbody>
        {skills.map((skill) => (
                <tr>
                    <!--<td class="skill-type">{skill.type}</td>-->
                    <td class="skill-info">
                        <span class="skill-name">{skill.name}</span>
                        {skill.subtext && <span class="skill-subtext">{skill.subtext}</span>}
                    </td>
                    <td>
                        <div class="level-container">
                            <span class="level-text">{skill.levelText}</span>
                            <div class="progress-bar" aria-label={`${skill.name} proficiency: ${skill.levelPercentage}%`}>
                                <div class="progress-fill" style={`width: ${skill.levelPercentage}%`}></div>
                            </div>
                        </div>
                    </td>
                    <td class="hide-mobile">
                        <div class="project-tags">
                            {skill.projects && skill.projects.map((project) => (
                                project.url ? (
                                        <a href={project.url} target="_blank" rel="noopener noreferrer" class="project-tag link">
                                            {project.name}
                                        </a>
                                ) : (
                                        <span class="project-tag">{project.name}</span>
                                )
                            ))}
                        </div>
                    </td>
                </tr>
        ))}
        </tbody>
    </table>
</div>

<style>
    /* Variables scoped to this table for easy customization */
    .skills-table-wrapper {
        --bg-card: #ffffff;
        --text-main: #1e293b;
        --text-muted: #64748b;
        --primary: #6366f1;
        --primary-light: #e0e7ff;
        --border: #e2e8f0;
        --row-hover: #f8fafc;

        width: 100%;
        background: var(--bg-card);
        border-radius: 12px;
        box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
        overflow: hidden;
        border: 1px solid var(--border);
        margin: 1.5rem 0;
    }

    /* Support Dark Mode if your site uses a .dark class on <html> or <body> */
    :global(html.dark) .skills-table-wrapper {
        --bg-card: #1e293b;
        --text-main: #f8fafc;
        --text-muted: #94a3b8;
        --primary: #818cf8;
        --primary-light: #312e81;
        --border: #334155;
        --row-hover: #334155;
    }

    .skills-table {
        width: 100%;
        border-collapse: collapse;
        text-align: left;
        font-family: system-ui, -apple-system, sans-serif;
    }

    th {
        background-color: rgba(0, 0, 0, 0.02);
        color: var(--text-muted);
        font-size: 0.8rem;
        text-transform: uppercase;
        letter-spacing: 0.05em;
        padding: 1rem 1.25rem;
        font-weight: 600;
    }

    :global(html.dark) th {
        background-color: rgba(255, 255, 255, 0.03);
    }

    tr {
        border-bottom: 1px solid var(--border);
        transition: background-color 0.2s ease;
    }

    tr:last-child {
        border-bottom: none;
    }

    tr:hover {
        background-color: var(--row-hover);
    }

    td {
        padding: 1rem 1.25rem;
        vertical-align: middle;
        font-size: 0.95rem;
        color: var(--text-main);
    }

    .skill-type {
        font-weight: 600;
    }

    .skill-info {
        display: flex;
        flex-direction: column;
    }

    .skill-name {
        font-weight: 500;
    }

    .skill-subtext {
        font-size: 0.8rem;
        color: var(--text-muted);
        margin-top: 0.15rem;
    }

    .level-container {
        display: flex;
        flex-direction: column;
        gap: 0.3rem;
        width: 130px;
    }

    .level-text {
        font-size: 0.8rem;
        font-weight: 600;
        color: var(--primary);
    }

    .progress-bar {
        width: 100%;
        height: 6px;
        background-color: var(--primary-light);
        border-radius: 99px;
        overflow: hidden;
    }

    .progress-fill {
        height: 100%;
        background-color: var(--primary);
        border-radius: 99px;
    }

    .project-tags {
        display: flex;
        flex-wrap: wrap;
        gap: 0.4rem;
    }

    .project-tag {
        background-color: rgba(0, 0, 0, 0.03);
        color: var(--text-main);
        padding: 0.2rem 0.6rem;
        border-radius: 6px;
        font-size: 0.8rem;
        border: 1px solid var(--border);
        white-space: nowrap;
    }

    :global(html.dark) .project-tag {
        background-color: rgba(255, 255, 255, 0.05);
    }

    .project-tag.link {
        text-decoration: none;
        transition: all 0.2s ease;
    }

    .project-tag.link:hover {
        border-color: var(--primary);
        color: var(--primary);
        background-color: var(--primary-light);
    }

    /* Responsive Design */
    @media (max-width: 640px) {
        .hide-mobile {
            display: none;
        }
        .level-container {
            width: 90px;
        }
    }
</style>
